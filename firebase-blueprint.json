{
  "entities": {
    "Profile": {
      "title": "User Profile",
      "description": "User profile with plan details",
      "type": "object",
      "properties": {
        "full_name": { "type": "string" },
        "email": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "monthly", "yearly"] },
        "plan_status": { "type": "string" },
        "plan_started_at": { "type": "number" },
        "plan_expires_at": { "type": "number" },
        "created_at": { "type": "number" }
      },
      "required": ["email", "plan"]
    },
    "Chat": {
      "title": "Chat",
      "description": "User's individual chat session",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "title": { "type": "string" },
        "created_at": { "type": "number" },
        "updated_at": { "type": "number" }
      },
      "required": ["user_id", "created_at"]
    },
    "Message": {
      "title": "Message",
      "description": "A single prompt or model response",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "created_at": { "type": "number" }
      },
      "required": ["user_id", "role", "content", "created_at"]
    },
    "GeneratedWebsite": {
      "title": "Generated Website",
      "description": "Data record of the final generated website files",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "chat_id": { "type": "string" },
        "title": { "type": "string" },
        "website_type": { "type": "string" },
        "prompt": { "type": "string" },
        "generated_files": { "type": "array" },
        "deployment_steps": { "type": "string" },
        "suggestions": { "type": "string" },
        "created_at": { "type": "number" }
      },
      "required": ["user_id", "created_at", "title"]
    },
    "UsageLimit": {
      "title": "Usage Limit",
      "description": "Tracking user generation quotas",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "weekly_generation_count": { "type": "number" },
        "last_generation_at": { "type": "number" },
        "next_free_generation_at": { "type": "number" },
        "total_generations": { "type": "number" },
        "updated_at": { "type": "number" }
      },
      "required": ["user_id"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Transaction and billing records",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "plan": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "status": { "type": "string" },
        "payment_provider": { "type": "string" },
        "razorpay_order_id": { "type": "string" },
        "razorpay_payment_id": { "type": "string" },
        "razorpay_signature": { "type": "string" },
        "created_at": { "type": "number" },
        "updated_at": { "type": "number" }
      },
      "required": ["user_id", "plan", "amount", "status", "created_at"]
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": { "$ref": "#/entities/Profile" },
      "description": "User profiles"
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Chats created by users"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages inside a chat"
    },
    "/generated_websites/{websiteId}": {
      "schema": { "$ref": "#/entities/GeneratedWebsite" },
      "description": "Websites generated by users"
    },
    "/usage_limits/{userId}": {
      "schema": { "$ref": "#/entities/UsageLimit" },
      "description": "Tracking of generative limits per user"
    },
    "/payments/{paymentId}": {
      "schema": { "$ref": "#/entities/Payment" },
      "description": "Logs of user transactions"
    }
  }
}
